document.getElementById('dl-btn').addEventListener('click', downloadExcel);
 
async function downloadExcel(){
  const from = document.getElementById('dl-from').value;
  const to = document.getElementById('dl-to').value;
  const branchFilter = document.getElementById('dl-branch').value;
  if(!from || !to){ toast('Pick a date range','warn'); return; }
  if(from > to){ toast('From date must be before To date','warn'); return; }
 
  const btn = document.getElementById('dl-btn');
  const info = document.getElementById('dl-info');
  btn.disabled = true;
  btn.textContent = '⟳ Loading library…';
 
  try{
    if(!window.XLSX){
      await loadScript('https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js');
    }
 
    btn.textContent = '⟳ Fetching entries…';
    const { data: cells, error } = await sb.from('cells')
      .select('vehicle,date,site_fill,site_hmr,fill_override,wh_override')
      .gte('date', from).lte('date', to)
      .not('site_fill','is',null)
      .order('date');
    if(error) throw error;
 
    if(!cells || !cells.length){
      toast('No entries in that date range','warn');
      btn.disabled = false;
      btn.textContent = '📥 DOWNLOAD EXCEL';
      return;
    }
 
    // Group by branch
    const byBranch = {};
    let unknownCount = 0;
    cells.forEach(c=>{
      let br = vehicleBranches[c.vehicle];
      if(!br){ br = 'Unknown'; unknownCount++; }
      if(branchFilter && br !== branchFilter) return; // skip if filtered out
      if(!byBranch[br]) byBranch[br] = [];
      byBranch[br].push(c);
    });
 
    if(!Object.keys(byBranch).length){
      toast(`No entries for ${branchFilter || 'any branch'} in that range`,'warn');
      btn.disabled = false;
      btn.textContent = '📥 DOWNLOAD EXCEL';
      return;
    }
 
    btn.textContent = '⟳ Building Excel…';
 
    const wb = XLSX.utils.book_new();
    const branches = Object.keys(byBranch).sort();
 
    // Helper to build a sheet from a flat array of entries
    function buildSheet(entries, includeBranch){
      const headers = includeBranch
        ? ['Date','Branch','Vehicle','Site Name','Site Fill (L)','Site HMR']
        : ['Date','Vehicle','Site Name','Site Fill (L)','Site HMR'];
      const rows = [headers];
      let totalFill = 0;
      entries
        .slice()
        .sort((a,b)=> a.date.localeCompare(b.date) || a.vehicle.localeCompare(b.vehicle))
        .forEach(c=>{
          const v = vehicles.find(x=> x.vehicle === c.vehicle);
          const siteName = v?.site_name || '';
          const fillVal = +c.site_fill || 0;
          totalFill += fillVal;
          if(includeBranch){
            rows.push([c.date, vehicleBranches[c.vehicle]||'Unknown', c.vehicle, siteName, fillVal, +c.site_hmr]);
          } else {
            rows.push([c.date, c.vehicle, siteName, fillVal, +c.site_hmr]);
          }
        });
      // Totals row
      rows.push([]);
      const totalRow = includeBranch
        ? ['','','','TOTAL', Math.round(totalFill*10)/10, '']
        : ['','','TOTAL', Math.round(totalFill*10)/10, ''];
      rows.push(totalRow);
      const ws = XLSX.utils.aoa_to_sheet(rows);
      // Set column widths
      ws['!cols'] = includeBranch
        ? [{wch:11},{wch:14},{wch:18},{wch:22},{wch:13},{wch:11}]
        : [{wch:11},{wch:18},{wch:22},{wch:13},{wch:11}];
      return ws;
    }
 
    // First sheet: All entries (with branch column) — only if more than 1 branch
    if(branches.length > 1){
      const all = [];
      branches.forEach(b => byBranch[b].forEach(c => all.push(c)));
      const sheetAll = buildSheet(all, true);
      XLSX.utils.book_append_sheet(wb, sheetAll, 'All Branches');
    }
 
    // One sheet per branch
    branches.forEach(branch => {
      const ws = buildSheet(byBranch[branch], false);
      // Excel sheet names: max 31 chars, no \ / ? * [ ] :
      const safe = branch.replace(/[\\\/\?\*\[\]:]/g,'').substring(0,31) || 'Branch';
      XLSX.utils.book_append_sheet(wb, ws, safe);
    });
 
    // Filename
    const fName = `TASR_Fuel_Entries_${from}_to_${to}${branchFilter?'_'+branchFilter.replace(/\s+/g,''):''}.xlsx`;
    XLSX.writeFile(wb, fName);
 
    info.textContent = `✓ ${cells.length} entries · ${branches.length} branch${branches.length===1?'':'es'}${unknownCount?` · ${unknownCount} unknown branch`:''}`;
    toast(`Downloaded ${cells.length} entries`);
  }catch(e){
    console.error('Download failed:', e);
    toast('Download failed: '+e.message, 'bad');
    info.textContent = '';
  }finally{
    btn.disabled = false;
    btn.textContent = '📥 DOWNLOAD EXCEL';
  }
}
 
