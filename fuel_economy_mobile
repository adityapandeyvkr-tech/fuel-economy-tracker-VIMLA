<script>
/* =========================================================
   TASR Fuel Entry — Mobile field app
   Same Supabase backend as the PC dashboard.
   Writes to: cells (vehicle, date, site_fill, site_hmr)
   Reads:     vehicles, cells
   Offline-safe: queues writes in localStorage if no network
========================================================= */
const SUPABASE_URL = 'https://nmupuithswsfqidrpxbc.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5tdXB1aXRoc3dzZnFpZHJweGJjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzcyMDY0MzAsImV4cCI6MjA5Mjc4MjQzMH0.lfTE0kqfa4Fg0EwPpZBrv9XLVlPGJgobfS-NltcFCBM';
const QUEUE_KEY = 'tasr_fuel_mobile_queue_v1';
 
const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
 
/* ========== SESSION / AUTH ========== */
const SESSION_KEY = 'tasr_session_v1';
let session = null;  // {managerId, managerName, branch, isAdmin}
 
function loadSession(){
  try{
    const s = JSON.parse(localStorage.getItem(SESSION_KEY) || 'null');
    if(s && s.managerId){ session = s; return true; }
  }catch(e){}
  return false;
}
function saveSession(){ localStorage.setItem(SESSION_KEY, JSON.stringify(session)); }
function clearSession(){ session = null; localStorage.removeItem(SESSION_KEY); }
 
function showPage(name){
  ['login','entry','admin'].forEach(p => {
    const el = document.getElementById('page-'+p);
    if(el) el.hidden = (p !== name);
  });
  const sub = document.getElementById('header-sub');
  const logoutBtn = document.getElementById('logout-btn');
  if(name === 'login'){
    sub.textContent = 'Sign in to continue';
    logoutBtn.hidden = true;
  } else if(name === 'entry'){
    sub.textContent = `${session.managerName}${session.branch?' · '+session.branch:''}`;
    logoutBtn.hidden = false;
  } else if(name === 'admin'){
    sub.textContent = '🔒 Admin Panel';
    logoutBtn.hidden = false;
  }
}
 
async function logout(){
  if(!confirm('Sign out?')) return;
  clearSession();
  vehicles = []; lastSiteHMR = {}; selectedVeh = null;
  showPage('login');
  await loadLoginOptions();
}
 
// State (existing)
let vehicles = [];
let lastSiteHMR = {};   // vehicle → { hmr, date }
let selectedVeh = null;
 
/* ========== Toast / status ========== */
function toast(msg, kind){
  const t = document.getElementById('toast');
  t.className = ''; if(kind) t.classList.add(kind);
  t.textContent = msg; t.classList.add('show');
  clearTimeout(toast._t);
  toast._t = setTimeout(()=> t.classList.remove('show'), 2400);
}
function setSync(state, text){
  const el = document.getElementById('sync-status');
  const cls = {good:'sync-good',warn:'sync-warn',bad:'sync-bad',pending:'sync-pending'}[state] || '';
  el.className = ''; if(cls) el.className = cls;
  el.textContent = text;
}
 
/* ========== Offline queue ========== */
function loadQueue(){
  try{ return JSON.parse(localStorage.getItem(QUEUE_KEY)||'[]') }
  catch(e){ return [] }
}
function saveQueue(q){ localStorage.setItem(QUEUE_KEY, JSON.stringify(q)) }
function queueSize(){ return loadQueue().length }
 
async function flushQueue(silent){
  const q = loadQueue();
  if(!q.length){ updateSyncStatus(); return; }
  if(!silent) setSync('pending', `⟳ ${q.length} pending…`);
  const stillPending = [];
  for(const entry of q){
    try{
      // Read-merge-write so we don't clobber other override columns
      const { data: existing, error: e1 } = await sb.from('cells').select('*')
        .eq('vehicle', entry.vehicle).eq('date', entry.date).maybeSingle();
      if(e1) throw e1;
      const merged = {
        vehicle: entry.vehicle, date: entry.date,
        fill_override: existing?.fill_override ?? null,
        wh_override: existing?.wh_override ?? null,
        site_fill: entry.site_fill,
        site_hmr: entry.site_hmr
      };
      const { error: e2 } = await sb.from('cells').upsert(merged, {onConflict:'vehicle,date'});
      if(e2) throw e2;
      // Update local hint cache
      lastSiteHMR[entry.vehicle] = { hmr: entry.site_hmr, date: entry.date };
    }catch(e){
      console.error('Queue replay failed:', e);
      stillPending.push(entry);
    }
  }
  saveQueue(stillPending);
  updateSyncStatus();
  if(stillPending.length === 0 && q.length > 0){
    toast(`✓ Synced ${q.length} pending entr${q.length===1?'y':'ies'}`);
  }
}
function updateSyncStatus(){
  const q = queueSize();
  if(!navigator.onLine){
    setSync('warn', `⚠ Offline${q?` · ${q} queued`:''}`);
  }else if(q > 0){
    setSync('pending', `⟳ ${q} pending`);
  }else{
    setSync('good', '☁ Synced');
  }
}
 
window.addEventListener('online', ()=> { toast('Back online — syncing…'); flushQueue(); });
window.addEventListener('offline', ()=> { toast('Offline — entries will sync later','warn'); updateSyncStatus(); });
setInterval(()=> { if(navigator.onLine) flushQueue(true); }, 30000);
 
/* ========== Loading data ========== */
async function loadVehicles(){
  try{
    const { data, error } = await sb.from('vehicles').select('*').order('vehicle');
    if(error) throw error;
    const allVehicles = data || [];
    if(session && !session.isAdmin){
      // Filter to assigned vehicles only
      const { data: assigns } = await sb.from('vehicle_assignments')
        .select('vehicle').eq('manager_id', session.managerId);
      const assignedSet = new Set((assigns||[]).map(a => a.vehicle));
      vehicles = allVehicles.filter(v => assignedSet.has(v.vehicle));
      if(!vehicles.length){
        toast('No vehicles assigned yet — ask admin','warn');
      }
    } else {
      vehicles = allVehicles;
    }
    if(!vehicles.length && !session){
      toast('No vehicles in database — upload Excel from PC first','warn');
    }
  }catch(e){
    console.error('loadVehicles failed:',e);
    toast('Could not load vehicles','bad');
  }
}
 
async function loadLastHMRs(){
  try{
    const { data, error } = await sb.from('cells')
      .select('vehicle,date,site_hmr')
      .not('site_hmr','is',null)
      .order('date',{ascending:false});
    if(error) throw error;
    lastSiteHMR = {};
    (data||[]).forEach(c=>{
      if(!lastSiteHMR[c.vehicle]) lastSiteHMR[c.vehicle] = { hmr:c.site_hmr, date:c.date };
    });
  }catch(e){
    console.error('loadLastHMRs failed:',e);
  }
}
 
async function loadEntriesForDate(){
  const date = document.getElementById('date').value;
  if(!date) return;
  const list = document.getElementById('ent-list');
  list.innerHTML = '<div class="loading"><div class="spinner"></div></div>';
  try{
    const { data, error } = await sb.from('cells')
      .select('vehicle,date,site_fill,site_hmr')
      .eq('date', date)
      .not('site_fill','is',null)
      .order('vehicle');
    if(error) throw error;
    renderEntries(data || []);
  }catch(e){
    list.innerHTML = '<div class="ent-empty" style="color:#b91c1c">Could not load entries</div>';
    document.getElementById('ent-count').textContent = '—';
  }
}
 
function renderEntries(rows){
  const list = document.getElementById('ent-list');
  document.getElementById('ent-count').textContent = rows.length;
  if(!rows.length){
    list.innerHTML = '<div class="ent-empty">No entries yet for this date</div>';
    return;
  }
  list.innerHTML = rows.map(c=>`
    <li class="ent-item">
      <button type="button" class="ent-tap" onclick="editEntry('${escapeAttr(c.vehicle)}','${c.date}',${+c.site_fill},${+c.site_hmr})">
        <div>
          <div class="ent-veh">${escapeHtml(c.vehicle)}</div>
          <div class="ent-vals">${fmt(c.site_fill)} L · HMR ${fmt(c.site_hmr)}</div>
        </div>
        <span class="ent-edit-hint">✏</span>
      </button>
      <button type="button" class="ent-del" onclick="deleteEntry('${escapeAttr(c.vehicle)}','${c.date}')" title="Remove">✕</button>
    </li>
  `).join('');
}
function fmt(n){ return (n==null)?'—':(+n).toFixed(1).replace(/\.0$/,'') }
function escapeHtml(s){ return String(s||'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])) }
function escapeAttr(s){ return String(s||'').replace(/'/g,"\\'") }
 
window.deleteEntry = async function(vehicle, date){
  if(!confirm(`Remove entry for ${vehicle} on ${date}?`)) return;
  try{
    // Capture before-state for audit
    const { data: existing } = await sb.from('cells').select('*')
      .eq('vehicle', vehicle).eq('date', date).maybeSingle();
    // Null out site_fill + site_hmr but keep the row so we don't kill other override fields
    const { error } = await sb.from('cells').update({
      site_fill: null, site_hmr: null
    }).eq('vehicle', vehicle).eq('date', date);
    if(error) throw error;
    // Refresh hint cache
    if(lastSiteHMR[vehicle] && lastSiteHMR[vehicle].date === date){
      delete lastSiteHMR[vehicle];
      await loadLastHMRs();
    }
    // Audit
    if(existing){
      logAudit(vehicle, date, 'delete',
        {site_fill: existing.site_fill, site_hmr: existing.site_hmr}, null);
    }
    toast('Entry removed');
    loadEntriesForDate();
  }catch(e){
    toast('Could not remove: '+e.message,'bad');
  }
};
 
/* ========== Edit mode ========== */
let editMode = false;
 
window.editEntry = function(vehicle, date, fill, hmr){
  const v = vehicles.find(x => x.vehicle === vehicle);
  if(!v){ toast('Vehicle not found','warn'); return; }
  editMode = true;
  selectedVeh = v;
  searchInput.value = vehicle;
  document.getElementById('date').value = date;
  document.getElementById('site-fill').value = fill;
  document.getElementById('site-hmr').value = hmr;
  searchResults.innerHTML = '';
  renderVehicleInfo();
 
  // Update UI to show edit state
  const btn = document.getElementById('save-btn');
  btn.textContent = '✏ UPDATE ENTRY';
  btn.classList.add('editing');
  document.getElementById('cancel-edit').style.display = 'block';
 
  // Scroll to top so they can see the form
  window.scrollTo({top:0, behavior:'smooth'});
};
 
function exitEditMode(){
  editMode = false;
  const btn = document.getElementById('save-btn');
  btn.textContent = 'SAVE ENTRY';
  btn.classList.remove('editing');
  const ce = document.getElementById('cancel-edit');
  if(ce) ce.style.display = 'none';
}
 
document.getElementById('cancel-edit').addEventListener('click', ()=>{
  exitEditMode();
  document.getElementById('site-fill').value = '';
  document.getElementById('site-hmr').value = '';
  searchInput.value = '';
  selectedVeh = null;
  document.getElementById('v-info').innerHTML = '';
  toast('Edit cancelled');
});
 
/* ========== Vehicle search / picker ========== */
const searchInput = document.getElementById('v-search');
const searchResults = document.getElementById('v-results');
 
searchInput.addEventListener('input', e=>{
  showVehicleDropdown(e.target.value.trim().toLowerCase());
});
searchInput.addEventListener('focus', e=>{
  // Show full list immediately when tapped (acts as a searchable dropdown)
  showVehicleDropdown(e.target.value.trim().toLowerCase());
});
 
function showVehicleDropdown(q){
  if(!vehicles.length){
    searchResults.innerHTML = `<div style="padding:14px;color:var(--muted);font-size:13px;text-align:center">No vehicles in database<br><span style="font-size:11px">Upload Excel from PC first</span></div>`;
    return;
  }
  const matches = !q ? vehicles : vehicles.filter(v=>{
    const name = (v.vehicle||'').toLowerCase();
    const site = (v.site_name||'').toLowerCase();
    const model = (v.model||'').toLowerCase();
    return name.includes(q) || site.includes(q) || model.includes(q);
  });
  if(!matches.length){
    searchResults.innerHTML = `<div style="padding:12px 14px;color:var(--muted);font-size:13px">No matching vehicle</div>`;
    return;
  }
  // Header showing count when displaying full list
  const header = !q ? `<div class="v-list-head">${matches.length} vehicles · type to filter</div>` : '';
  searchResults.innerHTML = header + matches.map(v=>{
    const isSelected = selectedVeh && selectedVeh.vehicle === v.vehicle;
    return `
    <button type="button" class="v-result${isSelected?' selected':''}" onclick="pickVehicle('${escapeAttr(v.vehicle)}')">
      <b>${escapeHtml(v.vehicle)}</b>
      <span>${escapeHtml(v.site_name||'(no site name)')}${v.model?' · '+escapeHtml(v.model):''}</span>
    </button>`;
  }).join('');
}
searchInput.addEventListener('blur', ()=> {
  // Delay so click on result button registers
  setTimeout(()=> { searchResults.innerHTML = ''; }, 200);
});
 
window.pickVehicle = function(vehName){
  selectedVeh = vehicles.find(v=>v.vehicle === vehName);
  if(!selectedVeh) return;
  searchInput.value = vehName;
  searchResults.innerHTML = '';
  renderVehicleInfo();
  // Auto-focus the fill input
  setTimeout(()=> document.getElementById('site-fill').focus(), 50);
};
 
function renderVehicleInfo(){
  const info = document.getElementById('v-info');
  if(!selectedVeh){ info.innerHTML = ''; return; }
  const last = lastSiteHMR[selectedVeh.vehicle];
  let lastHtml = '';
  if(last){
    const daysAgo = daysBetween(last.date, document.getElementById('date').value);
    const stale = daysAgo > 7;
    lastHtml = `
      <div class="row">
        <span>Last HMR: <b>${fmt(last.hmr)}</b></span>
        <span class="${stale?'stale':''}">${formatDate(last.date)}${daysAgo>0?` · ${daysAgo}d ago`:''}</span>
      </div>`;
  }else{
    lastHtml = `<div class="row"><span>Last HMR: —</span><span style="font-size:11px;color:var(--muted)">no previous fill</span></div>`;
  }
  info.innerHTML = `
    <div class="v-info">
      <div><span class="v-tag">${escapeHtml(selectedVeh.vehicle)}</span> ${escapeHtml(selectedVeh.site_name||'(no site set)')}</div>
      ${selectedVeh.model?`<div style="font-size:12px;color:#047857;margin-top:4px">${escapeHtml(selectedVeh.model)}</div>`:''}
      ${lastHtml}
    </div>`;
}
function daysBetween(d1, d2){
  if(!d1||!d2) return 0;
  const a = new Date(d1), b = new Date(d2);
  return Math.round((b-a)/(1000*60*60*24));
}
function formatDate(s){
  if(!s) return '';
  const [y,m,d] = s.split('-');
  return `${d}/${m}`;
}
 
/* ========== Save ========== */
document.getElementById('save-btn').addEventListener('click', saveEntry);
 
async function saveEntry(){
  const date = document.getElementById('date').value;
  const fillStr = document.getElementById('site-fill').value;
  const hmrStr = document.getElementById('site-hmr').value;
  if(!selectedVeh){ toast('Pick a vehicle first','warn'); searchInput.focus(); return; }
  if(!date){ toast('Pick a date','warn'); return; }
  if(fillStr === '' || isNaN(+fillStr)){ toast('Enter Site Fill (L)','warn'); document.getElementById('site-fill').focus(); return; }
  if(hmrStr === '' || isNaN(+hmrStr)){ toast('Enter HMR','warn'); document.getElementById('site-hmr').focus(); return; }
  const fill = +fillStr;
  const hmr = +hmrStr;
  if(fill <= 0){ toast('Site Fill must be > 0','warn'); return; }
  if(hmr < 0){ toast('HMR cannot be negative','warn'); return; }
 
  // HMR sanity check
  const last = lastSiteHMR[selectedVeh.vehicle];
  if(last && hmr < last.hmr){
    if(!confirm(`HMR ${hmr} is less than last recorded ${last.hmr} (${last.date}).\n\nIs the new reading correct?`)) return;
  }
 
  const btn = document.getElementById('save-btn');
  btn.disabled = true; btn.textContent = 'Saving…';
 
  const entry = {
    vehicle: selectedVeh.vehicle, date,
    site_fill: fill, site_hmr: hmr
  };
 
  let ok = false;
  let beforeState = null; // for audit
  if(navigator.onLine){
    try{
      const { data: existing, error: e1 } = await sb.from('cells').select('*')
        .eq('vehicle', entry.vehicle).eq('date', entry.date).maybeSingle();
      if(e1) throw e1;
      beforeState = existing;
      const merged = {
        vehicle: entry.vehicle, date: entry.date,
        fill_override: existing?.fill_override ?? null,
        wh_override: existing?.wh_override ?? null,
        site_fill: entry.site_fill, site_hmr: entry.site_hmr
      };
      const { error: e2 } = await sb.from('cells').upsert(merged, {onConflict:'vehicle,date'});
      if(e2) throw e2;
      ok = true;
      lastSiteHMR[entry.vehicle] = { hmr: entry.site_hmr, date: entry.date };
      // Audit log (fire-and-forget)
      const action = (existing && existing.site_fill != null) ? 'update' : 'create';
      logAudit(entry.vehicle, entry.date, action,
        existing ? {site_fill: existing.site_fill, site_hmr: existing.site_hmr} : null,
        {site_fill: entry.site_fill, site_hmr: entry.site_hmr});
    }catch(e){
      console.error('Save failed, queueing:', e);
    }
  }
  if(!ok){
    // Queue offline
    const q = loadQueue();
    q.push(entry);
    saveQueue(q);
    lastSiteHMR[entry.vehicle] = { hmr: entry.site_hmr, date: entry.date };
  }
 
  // Success UX
  btn.disabled = false;
  btn.classList.add('saved');
  const wasEdit = editMode;
  btn.textContent = ok ? (wasEdit ? '✓ UPDATED' : '✓ SAVED') : '✓ QUEUED';
  toast(ok ? `${wasEdit?'Updated':'Saved'} · ${selectedVeh.vehicle}` : `Queued · will sync when online`);
  setTimeout(()=>{
    btn.classList.remove('saved');
    btn.textContent = 'SAVE ENTRY';
  }, 1800);
 
  // Clear form, exit edit mode, focus search for next entry
  exitEditMode();
