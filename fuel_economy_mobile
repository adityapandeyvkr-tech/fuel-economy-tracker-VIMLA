async function autoAssignByBranch(){
  // For each unassigned vehicle, find a manager whose branch matches
  const assignMap = {};
  allAssignments.forEach(a => { assignMap[a.vehicle] = a.manager_id; });
  const branchToMgr = {};
  allManagers.filter(m => !m.is_admin && m.active && m.branch).forEach(m => {
    if(!branchToMgr[m.branch]) branchToMgr[m.branch] = m.id;
  });
  const toAssign = [];
  allVehiclesAdmin.forEach(v => {
    if(assignMap[v.vehicle]) return;
    const branch = vehicleBranches[v.vehicle];
    if(branch && branchToMgr[branch]){
      toAssign.push({vehicle: v.vehicle, manager_id: branchToMgr[branch], assigned_at: new Date().toISOString()});
    }
  });
  if(!toAssign.length){ toast('Nothing to auto-assign — add managers with branches first','warn'); return; }
  if(!confirm(`Auto-assign ${toAssign.length} vehicle${toAssign.length===1?'':'s'} to matching branch managers?`)) return;
  try{
    const { error } = await sb.from('vehicle_assignments').upsert(toAssign, {onConflict:'vehicle'});
    if(error) throw error;
    toast(`Auto-assigned ${toAssign.length} vehicles`);
    await loadAssignments();
  }catch(e){
    toast('Failed: '+e.message,'bad');
  }
}
 
