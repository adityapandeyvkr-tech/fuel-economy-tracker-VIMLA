async function loadAuditLog(){
  const from = document.getElementById('audit-from').value;
  const to = document.getElementById('audit-to').value;
  const mgrId = document.getElementById('audit-manager').value;
  const list = document.getElementById('audit-list');
  list.innerHTML = '<div class="loading"><div class="spinner"></div></div>';
  try{
    // Populate manager dropdown if empty
    const mgrSel = document.getElementById('audit-manager');
    if(mgrSel.options.length <= 1 && allManagers.length){
      mgrSel.innerHTML = '<option value="">All managers</option>' +
        allManagers.map(m=> `<option value="${m.id}">${escapeHtml(m.name)}</option>`).join('');
    }
    let q = sb.from('entry_audit').select('*').order('created_at',{ascending:false}).limit(200);
    if(from) q = q.gte('created_at', from + 'T00:00:00');
    if(to) q = q.lte('created_at', to + 'T23:59:59');
    if(mgrId) q = q.eq('manager_id', +mgrId);
    const { data, error } = await q;
    if(error) throw error;
    renderAuditLog(data || []);
  }catch(e){
    console.error('loadAuditLog failed:',e);
    list.innerHTML = '<div class="ent-empty" style="color:#b91c1c">Could not load audit log</div>';
  }
}
 
function renderAuditLog(rows){
  const list = document.getElementById('audit-list');
  if(!rows.length){
    list.innerHTML = '<div class="ent-empty">No audit entries in this range</div>';
    return;
  }
  list.innerHTML = rows.map(r=>{
    const dt = new Date(r.created_at);
    const when = dt.toLocaleDateString('en-IN',{day:'2-digit',month:'short'}) + ' ' +
                 dt.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:false});
    let delta = '';
    if(r.action === 'create'){
      delta = `<div class="delta">→ Fill: <b>${fmt(r.after_fill)} L</b> · HMR: <b>${fmt(r.after_hmr)}</b></div>`;
    } else if(r.action === 'update'){
      const fillChanged = r.before_fill !== r.after_fill;
      const hmrChanged = r.before_hmr !== r.after_hmr;
      delta = `<div class="delta">
        ${fillChanged?`Fill: <b style="color:#92400e">${fmt(r.before_fill)}</b> → <b style="color:#1e40af">${fmt(r.after_fill)} L</b>`:''}
        ${fillChanged && hmrChanged?' · ':''}
        ${hmrChanged?`HMR: <b style="color:#92400e">${fmt(r.before_hmr)}</b> → <b style="color:#1e40af">${fmt(r.after_hmr)}</b>`:''}
        ${!fillChanged && !hmrChanged?'<span style="color:var(--muted)">no change recorded</span>':''}
      </div>`;
    } else if(r.action === 'delete'){
      delta = `<div class="delta">Removed: ${fmt(r.before_fill)} L · HMR ${fmt(r.before_hmr)}</div>`;
    }
    return `
      <div class="audit-card ${r.action}">
        <div class="top">
          <span class="when">${when}</span>
          <span class="act ${r.action}">${r.action}</span>
        </div>
        <div class="veh-line">${escapeHtml(r.vehicle)} · ${formatDate(r.entry_date)}</div>
        <div class="by">by <b>${escapeHtml(r.manager_name||'(unknown)')}</b></div>
        ${delta}
      </div>`;
  }).join('');
}
 
/* --- Modal helpers --- */
function showModal(title, bodyHtml){
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-body').innerHTML = bodyHtml;
  document.getElementById('modal').hidden = false;
  document.body.style.overflow = 'hidden';
}
function closeModal(){
  document.getElementById('modal').hidden = true;
  document.body.style.overflow = '';
}
window.closeModal = closeModal;
 
document.getElementById('modal-close').onclick = closeModal;
document.querySelector('.modal-backdrop').onclick = closeModal;
 
/* ========== Init ========== */
document.addEventListener('DOMContentLoaded', async ()=>{
  // Default to today (local timezone)
  const today = new Date();
  today.setMinutes(today.getMinutes() - today.getTimezoneOffset());
  const todayStr = today.toISOString().slice(0,10);
  document.getElementById('date').value = todayStr;
  document.getElementById('date').addEventListener('change', ()=>{
    loadEntriesForDate();
    if(selectedVeh) renderVehicleInfo();
  });
 
  // Default download range
  const monthStart = new Date(today.getFullYear(), today.getMonth(), 1);
  monthStart.setMinutes(monthStart.getMinutes() - monthStart.getTimezoneOffset());
  document.getElementById('dl-from').value = monthStart.toISOString().slice(0,10);
  document.getElementById('dl-to').value = todayStr;
 
  // Login wiring
  document.getElementById('login-btn').onclick = attemptLogin;
  document.getElementById('login-pin').addEventListener('keydown', e=>{
    if(e.key === 'Enter') attemptLogin();
  });
  document.getElementById('logout-btn').onclick = logout;
 
  // Auth boot
  if(loadSession()){
    await initAfterLogin();
  } else {
    showPage('login');
    await loadLoginOptions();
  }
});
 
</script>
