<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<meta name="theme-color" content="#0d8585">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="TASR Fuel">
<title>TASR Fuel Entry</title>
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%230d8585'/%3E%3Ctext x='50' y='62' text-anchor='middle' font-family='system-ui' font-size='38' font-weight='800' fill='white'%3E⛽%3C/text%3E%3C/svg%3E">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<style>
  *,*::before,*::after{box-sizing:border-box}
  :root{
    --primary:#0d8585; --primary-dark:#075c5c;
    --ink:#0f172a; --ink-2:#475569; --muted:#64748b;
    --line:#e2e8f0; --bg:#f1f5f9; --card:#fff;
    --good:#059669; --warn:#f59e0b; --bad:#dc2626;
  }
  html,body{margin:0;padding:0;height:100%;overflow-x:hidden}
  body{
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;
    background:var(--bg);color:var(--ink);font-size:16px;
    -webkit-font-smoothing:antialiased;
    padding-bottom:env(safe-area-inset-bottom);
  }
  /* Header */
  header{
    background:linear-gradient(135deg,#0f172a 0%,#1e293b 100%);
    color:#fff;padding:14px 16px;position:sticky;top:0;z-index:50;
    padding-top:calc(14px + env(safe-area-inset-top));
    box-shadow:0 2px 8px rgba(0,0,0,.1);
  }
  .hd-row{display:flex;align-items:center;justify-content:space-between;gap:10px}
  .hd-right{display:flex;align-items:center;gap:8px}
  #logout-btn{
    background:rgba(255,255,255,.1);color:#fff;border:1px solid rgba(255,255,255,.15);
    width:32px;height:32px;border-radius:8px;font-size:14px;cursor:pointer;
    display:grid;place-items:center;
  }
  #logout-btn:active{background:rgba(255,255,255,.2)}
 
  /* === LOGIN PAGE === */
  .login-card{
    margin:30px auto 12px;text-align:center;padding:30px 24px 24px;
  }
  .login-icon{font-size:42px;margin-bottom:6px}
  .login-title{margin:0 0 4px;font-size:22px;font-weight:700}
  .login-sub{margin:0 0 22px;color:var(--muted);font-size:13px}
  .login-card .field{text-align:left}
  .login-card select{
    width:100%;font-size:16px;padding:13px 14px;
    border:2px solid var(--line);border-radius:10px;background:#fff;
    font-family:inherit;color:var(--ink);-webkit-appearance:none;appearance:none;
    background-image:url("data:image/svg+xml;charset=US-ASCII,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12'%3E%3Cpath d='M2 4l4 4 4-4' stroke='%2364748b' stroke-width='1.5' fill='none'/%3E%3C/svg%3E");
    background-repeat:no-repeat;background-position:right 12px center;background-size:14px;padding-right:36px;
  }
  .login-card #login-pin{
    text-align:center;font-size:24px;letter-spacing:.4em;font-weight:700;
  }
  #login-btn{
    width:100%;padding:16px;
    background:linear-gradient(135deg,#0d8585 0%,#075c5c 100%);
    color:#fff;border:none;border-radius:12px;
    font-size:16px;font-weight:700;letter-spacing:.06em;
    cursor:pointer;font-family:inherit;
    box-shadow:0 4px 14px rgba(13,133,133,.3);
  }
  #login-btn:active{transform:translateY(1px)}
  #login-btn:disabled{opacity:.6}
  .login-error{
    margin-top:12px;padding:10px 12px;background:#fee2e2;border:1px solid #fca5a5;
    border-radius:8px;color:#991b1b;font-size:13px;font-weight:600;
  }
  .login-foot{
    text-align:center;color:var(--muted);font-size:11px;padding:18px 12px;line-height:1.6;
  }
 
  /* === ADMIN PAGE === */
  .admin-tabs{
    display:flex;gap:4px;background:#fff;border-radius:12px;padding:4px;
    margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.04);
  }
  .atab{
    flex:1;padding:10px 6px;background:transparent;border:none;
    font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;
    border-radius:8px;font-family:inherit;
    transition:all .15s;
  }
  .atab.active{background:var(--primary);color:#fff;box-shadow:0 2px 6px rgba(13,133,133,.25)}
  .atab-add{
    width:100%;padding:12px;background:#0f172a;color:#fff;
    border:none;border-radius:10px;font-size:14px;font-weight:700;
    cursor:pointer;font-family:inherit;margin-bottom:12px;
  }
  .atab-add:active{transform:translateY(1px)}
  .atab-mini{
    flex:1;padding:7px 4px;background:#f1f5f9;border:1px solid var(--line);
    border-radius:7px;font-size:11px;font-weight:600;color:var(--ink-2);
    cursor:pointer;font-family:inherit;
  }
  .atab-mini.active{background:var(--primary);color:#fff;border-color:var(--primary)}
 
  /* Manager card */
  .mgr-card{
    background:#fff;border-radius:12px;padding:14px;margin-bottom:8px;
    border:1px solid var(--line);
  }
  .mgr-card .top{display:flex;align-items:center;justify-content:space-between;gap:8px}
  .mgr-card .nm{font-size:15px;font-weight:700}
  .mgr-card .role{
    font-size:10px;font-weight:700;padding:2px 8px;border-radius:99px;
    text-transform:uppercase;letter-spacing:.04em;
  }
  .mgr-card .role.admin{background:#fef3c7;color:#92400e;border:1px solid #fcd34d}
  .mgr-card .role.mgr{background:#dbeafe;color:#1e40af;border:1px solid #93c5fd}
  .mgr-card .meta{font-size:12px;color:var(--muted);margin-top:6px;line-height:1.6}
  .mgr-card .actions{display:flex;gap:6px;margin-top:10px}
  .mgr-card .actions button{
    flex:1;padding:8px;border-radius:8px;font-size:12px;font-weight:600;
    cursor:pointer;font-family:inherit;border:1px solid var(--line);
  }
  .mgr-edit{background:#dbeafe;color:#1e40af;border-color:#93c5fd !important}
  .mgr-pin{background:#fef3c7;color:#92400e;border-color:#fcd34d !important}
  .mgr-del{background:#fee2e2;color:#991b1b;border-color:#fca5a5 !important}
 
  /* Assignment card */
  .assign-card{
    background:#fff;border-radius:10px;padding:11px 12px;margin-bottom:6px;
    border:1px solid var(--line);
    display:flex;align-items:center;justify-content:space-between;gap:8px;
  }
  .assign-card .veh{font-weight:600;font-size:14px}
  .assign-card .meta{font-size:11px;color:var(--muted);margin-top:2px}
  .assign-card select{
    font-size:13px;padding:7px 24px 7px 10px;border:1px solid var(--line);
    border-radius:7px;background:#fff;max-width:140px;
    -webkit-appearance:none;appearance:none;
    background-image:url("data:image/svg+xml;charset=US-ASCII,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 12 12'%3E%3Cpath d='M2 4l4 4 4-4' stroke='%2364748b' stroke-width='1.5' fill='none'/%3E%3C/svg%3E");
    background-repeat:no-repeat;background-position:right 6px center;background-size:12px;
  }
  .assign-card.unassigned{background:#fffbeb;border-color:#fcd34d}
 
  /* Audit log card */
  .audit-card{
    background:#fff;border-radius:10px;padding:11px 12px;margin-bottom:6px;
    border:1px solid var(--line);
    border-left:3px solid var(--primary);
  }
  .audit-card.create{border-left-color:#10b981}
  .audit-card.update{border-left-color:#3b82f6}
  .audit-card.delete{border-left-color:#dc2626}
  .audit-card .top{display:flex;justify-content:space-between;align-items:center;gap:8px;font-size:11px}
  .audit-card .when{color:var(--muted);font-variant-numeric:tabular-nums}
  .audit-card .act{font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:10px;padding:2px 7px;border-radius:99px}
  .audit-card .act.create{background:#dcfce7;color:#065f46}
  .audit-card .act.update{background:#dbeafe;color:#1e40af}
  .audit-card .act.delete{background:#fee2e2;color:#991b1b}
  .audit-card .veh-line{font-size:14px;font-weight:600;margin:6px 0 2px}
  .audit-card .by{font-size:11px;color:var(--muted)}
  .audit-card .delta{
    margin-top:6px;font-size:12px;font-variant-numeric:tabular-nums;
    background:#f8fafc;padding:6px 8px;border-radius:6px;
  }
 
  /* === MODAL === */
  .modal{
    position:fixed;inset:0;z-index:1000;
    display:flex;align-items:center;justify-content:center;padding:20px;
  }
  .modal[hidden]{display:none !important}
  .modal-backdrop{
    position:absolute;inset:0;background:rgba(15,23,42,.55);
    -webkit-backdrop-filter:blur(2px);backdrop-filter:blur(2px);
  }
  .modal-content{
    position:relative;background:#fff;border-radius:14px;
    width:100%;max-width:420px;max-height:90vh;overflow-y:auto;
    box-shadow:0 20px 60px rgba(0,0,0,.3);
  }
  .modal-head{
    display:flex;align-items:center;justify-content:space-between;
    padding:16px 18px;border-bottom:1px solid var(--line);
    position:sticky;top:0;background:#fff;
  }
  .modal-head h3{margin:0;font-size:16px;font-weight:700}
  #modal-close{
    background:#f1f5f9;border:none;width:32px;height:32px;
    border-radius:8px;font-size:14px;cursor:pointer;
  }
  #modal-body{padding:18px}
  #modal-body .field input,#modal-body .field select{
    width:100%;font-size:15px;padding:11px 12px;
    border:2px solid var(--line);border-radius:10px;background:#fff;
    font-family:inherit;-webkit-appearance:none;appearance:none;
  }
  #modal-body .modal-actions{display:flex;gap:8px;margin-top:16px}
  #modal-body .modal-actions button{
    flex:1;padding:12px;border:none;border-radius:10px;
    font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;
  }
  #modal-body .btn-primary{background:var(--primary);color:#fff}
  #modal-body .btn-secondary{background:#f1f5f9;color:var(--ink-2);border:1px solid var(--line)}
  #modal-body .btn-danger{background:#dc2626;color:#fff}
  .brand{display:flex;align-items:center;gap:10px}
  .logo{
    width:36px;height:36px;border-radius:9px;
    background:linear-gradient(135deg,#0d8585 0%,#075c5c 100%);
    display:grid;place-items:center;font-size:18px;
  }
  .title{font-size:15px;font-weight:700;letter-spacing:-.01em}
  .subtitle{font-size:11px;opacity:.65;margin-top:1px}
  #sync-status{
    font-size:11px;padding:4px 10px;border-radius:99px;
    background:rgba(255,255,255,.08);font-weight:600;cursor:pointer;
    border:1px solid rgba(255,255,255,.1);
  }
  /* Main */
  main{padding:18px 16px;max-width:520px;margin:0 auto}
 
  .card{
    background:var(--card);border-radius:14px;padding:16px;margin-bottom:14px;
    box-shadow:0 1px 3px rgba(0,0,0,.04);
  }
  .field{margin-bottom:14px}
  .field:last-child{margin-bottom:0}
  label{
    display:block;font-size:11px;font-weight:700;letter-spacing:.06em;
    text-transform:uppercase;color:var(--muted);margin-bottom:6px;
  }
  input[type="date"],input[type="text"],input[type="number"]{
    width:100%;font-size:17px;padding:13px 14px;
    border:2px solid var(--line);border-radius:10px;background:#fff;
    font-family:inherit;color:var(--ink);
    -webkit-appearance:none;appearance:none;
    transition:border-color .15s;
  }
  input:focus{outline:none;border-color:var(--primary)}
  input[type="number"]{font-variant-numeric:tabular-nums;font-weight:600}
 
  .big-num{font-size:22px !important;font-weight:700 !important;text-align:center}
 
  /* Vehicle picker */
  .v-search-wrap{position:relative}
  .v-search-wrap input{padding-right:36px}
  .v-chevron{
    position:absolute;right:12px;top:50%;transform:translateY(-50%);
    color:var(--muted);font-size:10px;pointer-events:none;
    transition:transform .2s;
  }
  .v-search-wrap input:focus + .v-chevron{transform:translateY(-50%) rotate(180deg);color:var(--primary)}
  .v-results{
    position:absolute;top:calc(100% + 4px);left:0;right:0;
    background:#fff;border-radius:12px;
    box-shadow:0 8px 24px rgba(0,0,0,.12);
    max-height:55vh;overflow-y:auto;z-index:20;
    border:1px solid var(--line);
  }
  .v-results:empty{display:none}
  .v-list-head{
    position:sticky;top:0;background:#f8fafc;
    padding:8px 14px;font-size:11px;font-weight:600;
    color:var(--muted);text-transform:uppercase;letter-spacing:.04em;
    border-bottom:1px solid var(--line);
  }
  .v-result{
    display:block;width:100%;text-align:left;
    padding:12px 14px;border:none;background:#fff;
    border-bottom:1px solid #f1f5f9;font-size:15px;
    cursor:pointer;font-family:inherit;
  }
  .v-result:active{background:var(--bg)}
  .v-result.selected{background:#ecfdf5;border-left:3px solid var(--good)}
  .v-result:last-child{border-bottom:none}
  .v-result b{display:block;color:var(--ink);font-weight:600}
  .v-result span{
    display:block;font-size:12px;color:var(--muted);margin-top:2px;
  }
  .v-info{
    margin-top:8px;background:#ecfdf5;border:1px solid #a7f3d0;
    border-radius:10px;padding:10px 12px;font-size:13px;color:#065f46;
  }
  .v-info .v-tag{
    display:inline-block;background:#fff;color:#047857;border:1px solid #a7f3d0;
    padding:2px 8px;border-radius:4px;font-weight:700;font-size:12px;margin-right:6px;
  }
  .v-info .row{display:flex;justify-content:space-between;align-items:center;margin-top:4px}
  .v-info .row b{font-variant-numeric:tabular-nums}
  .v-info .stale{color:#92400e;background:#fffbeb;border-color:#fcd34d;padding:2px 6px;border-radius:4px;font-size:11px;font-weight:600}
 
  /* Save button */
  #save-btn{
    width:100%;padding:18px;
    background:linear-gradient(135deg,var(--good) 0%,#047857 100%);
    color:#fff;border:none;border-radius:14px;
    font-size:17px;font-weight:700;letter-spacing:.04em;
    cursor:pointer;font-family:inherit;
    box-shadow:0 4px 14px rgba(5,150,105,.35);
    transition:all .15s;
    -webkit-tap-highlight-color:transparent;
  }
  #save-btn:active{transform:translateY(1px);box-shadow:0 2px 8px rgba(5,150,105,.35)}
  #save-btn:disabled{opacity:.5;cursor:not-allowed}
  #save-btn.saved{background:linear-gradient(135deg,#10b981 0%,#059669 100%);animation:pop .3s}
  @keyframes pop{0%,100%{transform:scale(1)}50%{transform:scale(1.02)}}
 
  /* Today's entries */
  .ent-head{
    display:flex;align-items:center;justify-content:space-between;
    margin-bottom:10px;
  }
  .ent-head h3{
    margin:0;font-size:11px;font-weight:700;letter-spacing:.06em;
    text-transform:uppercase;color:var(--muted);
  }
  .ent-count{
    font-size:11px;font-weight:700;color:var(--primary);
    background:#e6fffa;padding:2px 8px;border-radius:99px;
  }
  .ent-list{list-style:none;padding:0;margin:0}
  .ent-item{
    display:flex;align-items:center;gap:6px;
    padding:0;background:#fff;border-radius:10px;margin-bottom:6px;
    border:1px solid var(--line);overflow:hidden;
  }
  .ent-tap{
    flex:1;display:flex;align-items:center;justify-content:space-between;
    padding:11px 12px;background:transparent;border:none;
    text-align:left;font-family:inherit;cursor:pointer;
    -webkit-tap-highlight-color:transparent;
  }
  .ent-tap:active{background:var(--bg)}
  .ent-veh{font-weight:600;font-size:14px;color:var(--ink)}
  .ent-vals{font-size:12px;color:var(--muted);margin-top:2px;font-variant-numeric:tabular-nums}
  .ent-edit-hint{
    font-size:14px;color:var(--primary);opacity:.5;
    background:#e6fffa;padding:4px 8px;border-radius:6px;
  }
  .ent-tap:active .ent-edit-hint{opacity:1}
  .ent-del{
    background:#fee2e2;color:#b91c1c;border:none;
    width:34px;height:34px;border-radius:50%;font-size:14px;cursor:pointer;
    display:grid;place-items:center;margin-right:8px;flex-shrink:0;
  }
  .ent-del:active{background:#fecaca}
  .ent-empty{
    text-align:center;color:#94a3b8;padding:18px 12px;
    background:#fff;border-radius:10px;font-size:13px;
    border:1px dashed var(--line);
  }
 
  /* Save button - edit mode */
  #save-btn.editing{
    background:linear-gradient(135deg,#2563eb 0%,#1d4ed8 100%);
    box-shadow:0 4px 14px rgba(37,99,235,.35);
  }
 
  /* Download section */
  .dl-quick{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
  .dl-quick button{
    flex:1;min-width:60px;padding:8px 10px;
    background:#f1f5f9;border:1px solid var(--line);border-radius:8px;
    font-size:12px;font-weight:600;color:var(--ink-2);cursor:pointer;
    font-family:inherit;
  }
  .dl-quick button:active,.dl-quick button.active{
    background:var(--primary);color:#fff;border-color:var(--primary);
  }
  #dl-btn{
    width:100%;padding:14px;
    background:linear-gradient(135deg,#7c3aed 0%,#6d28d9 100%);
    color:#fff;border:none;border-radius:12px;
    font-size:15px;font-weight:700;letter-spacing:.04em;
    cursor:pointer;font-family:inherit;
    box-shadow:0 4px 14px rgba(124,58,237,.3);
  }
  #dl-btn:active{transform:translateY(1px)}
  #dl-btn:disabled{opacity:.5;cursor:not-allowed}
 
  /* Toast */
  #toast{
    position:fixed;bottom:24px;left:50%;transform:translateX(-50%);
    background:var(--ink);color:#fff;
    padding:12px 18px;border-radius:99px;
    font-size:13px;font-weight:600;
    box-shadow:0 8px 24px rgba(0,0,0,.25);
    opacity:0;pointer-events:none;transition:opacity .25s,transform .25s;
    z-index:100;max-width:90vw;
  }
  #toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
  #toast.warn{background:#92400e}
  #toast.bad{background:#991b1b}
 
  /* Sync states */
  .sync-good{color:#10b981 !important}
  .sync-warn{color:#fbbf24 !important}
  .sync-bad{color:#fca5a5 !important}
  .sync-pending{color:#fbbf24 !important}
 
  /* Utility */
  .row{display:flex;gap:10px}
  .row > .field{flex:1}
 
  /* Loading */
  .loading{
    display:grid;place-items:center;padding:40px 20px;color:var(--muted);
  }
  .spinner{
    width:24px;height:24px;border:2.5px solid #e2e8f0;border-top-color:var(--primary);
    border-radius:50%;animation:spin .7s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg)}}
 
  /* Mobile-specific tweaks */
  @media (max-width:380px){
    main{padding:14px 12px}
    .card{padding:14px}
    .title{font-size:14px}
  }
</style>
</head>
<body>
<header>
  <div class="hd-row">
    <div class="brand">
      <div class="logo">⛽</div>
      <div>
        <div class="title">TASR Fuel Entry</div>
        <div class="subtitle" id="header-sub">Sign in to continue</div>
      </div>
    </div>
    <div class="hd-right">
      <span id="sync-status" title="Cloud sync status">◌ …</span>
      <button id="logout-btn" type="button" hidden title="Sign out">↗</button>
    </div>
  </div>
</header>
 
<!-- ============ LOGIN PAGE ============ -->
<main id="page-login" hidden>
  <div class="card login-card">
    <div class="login-icon">🔐</div>
    <h2 class="login-title">Sign In</h2>
    <p class="login-sub">Pick your site and enter the PIN</p>
    <div class="field">
      <label>Site / Role</label>
      <select id="login-site"><option>Loading…</option></select>
    </div>
    <div class="field">
      <label>PIN</label>
      <input type="password" id="login-pin" inputmode="numeric" maxlength="6" placeholder="••••" autocomplete="off">
    </div>
    <button id="login-btn" type="button">SIGN IN</button>
    <div id="login-error" class="login-error" hidden></div>
  </div>
  <div class="login-foot">
    No account? Ask your admin to create one.<br>
    <span style="opacity:.6">First-time setup: log in as <b>Admin</b> with PIN <b>9999</b></span>
  </div>
</main>
 
<!-- ============ ENTRY PAGE (site managers) ============ -->
<main id="page-entry" hidden>
  <div class="card">
    <div class="field">
      <label>Date</label>
      <input type="date" id="date">
    </div>
 
    <div class="field">
      <label>Vehicle</label>
      <div class="v-search-wrap">
        <input type="text" id="v-search" placeholder="Tap to choose vehicle…" autocomplete="off">
        <div class="v-chevron">▼</div>
        <div class="v-results" id="v-results"></div>
      </div>
      <div id="v-info"></div>
    </div>
 
    <div class="row">
      <div class="field">
        <label>Site Fill (L)</label>
        <input type="number" id="site-fill" inputmode="decimal" step="0.1" placeholder="0.0" class="big-num">
      </div>
